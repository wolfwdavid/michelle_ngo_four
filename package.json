{
  "name": "michelle-ngo-four",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:data": "vitest run src/lib/data/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "22.19.18",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.4",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.5",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.7",
    "vitest": "4.1.5",
    "zod": "4.4.3"
  }
}
